APP_NAME=ElectroFix-AI
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

LOG_CHANNEL=stack
LOG_STACK=single,observability
LOG_LEVEL=info
OBSERVABILITY_CHANNEL=observability
OBSERVABILITY_LOG_LEVEL=info
OBSERVABILITY_EXTERNAL_ENABLED=false
OBSERVABILITY_EXTERNAL_DRIVER=none
OBSERVABILITY_EXTERNAL_ENDPOINT=
OBSERVABILITY_EXTERNAL_API_KEY=
OBSERVABILITY_EXTERNAL_TIMEOUT_SECONDS=3

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=electrofix_ai
DB_USERNAME=electrofix_user
DB_PASSWORD=change_me

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.your-domain.com

CACHE_STORE=file
QUEUE_CONNECTION=sync
# NOTA PARA MIGRACIÓN A VPS:
# Cambiar QUEUE_CONNECTION=database y ejecutar:
#   php artisan queue:work --queue=default --tries=3
# Asegurarse de que la tabla 'jobs' existe (ya incluida en las migraciones).

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=15
GROQ_ARIS_MODEL=llama-3.3-70b-versatile
GROQ_SYSTEM_PROMPT=

SUPPORT_EMAIL=soporte@your-domain.com
TRIAL_PROMO_START_DATE=2026-03-30
TRIAL_PROMO_START_TIME=01:00:00
TRIAL_PROMO_TIMEZONE=America/Mexico_City
TRIAL_PROMO_DURATION_MONTHS=6

# Gemini (opcional, activar con AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=12
